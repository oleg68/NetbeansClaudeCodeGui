<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN"
    "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <folder name="OptionsDialog">
        <file name="ClaudeCodeGUI.instance">
            <attr methodvalue="org.netbeans.spi.options.OptionsCategory.createCategory"
                  name="instanceCreate"/>
            <attr name="controller"
                  newvalue="io.github.nbclaudecodegui.settings.ClaudeCodeOptionsPanelController"/>
            <attr bundlevalue="io.github.nbclaudecodegui.Bundle#OptionsCategory_Name_ClaudeCodeGUI"
                  name="categoryName"/>
            <attr name="iconBase"
                  stringvalue="io/github/nbclaudecodegui/icons/claude-icon-32.png"/>
            <attr bundlevalue="io.github.nbclaudecodegui.Bundle#OptionsCategory_Keywords_ClaudeCodeGUI"
                  name="keywords"/>
            <attr name="keywordsCategory" stringvalue="ClaudeCodeGUI"/>
            <attr name="position" intvalue="1500"/>
        </file>
    </folder>

    <!-- MIME resolver: .md / .markdown → text/x-markdown (fallback when netbeans-markdown is absent) -->
    <folder name="Services">
        <folder name="MIMEResolver">
            <file name="io-github-nbclaudecodegui-markdown-mime-resolver.xml"
                  url="markdown-mime-resolver.xml">
                <attr name="position" intvalue="9000"/>
            </file>
        </folder>
    </folder>

    <!-- Project Properties — Claude Code panel (Maven) -->
    <folder name="Projects">
        <folder name="org-netbeans-modules-maven">
            <folder name="Customizer">
                <file name="ClaudeCodePanelProvider.instance">
                    <attr name="instanceCreate"
                          newvalue="io.github.nbclaudecodegui.settings.ClaudeProjectPropertiesPanelProvider"/>
                    <attr name="position" intvalue="900"/>
                </file>
            </folder>
        </folder>
        <folder name="org-netbeans-modules-java-j2seproject">
            <folder name="Customizer">
                <file name="ClaudeCodePanelProvider.instance">
                    <attr name="instanceCreate"
                          newvalue="io.github.nbclaudecodegui.settings.ClaudeProjectPropertiesPanelProvider"/>
                    <attr name="position" intvalue="900"/>
                </file>
            </folder>
        </folder>
        <folder name="org-netbeans-modules-gradle">
            <folder name="Customizer">
                <file name="ClaudeCodePanelProvider.instance">
                    <attr name="instanceCreate"
                          newvalue="io.github.nbclaudecodegui.settings.ClaudeProjectPropertiesPanelProvider"/>
                    <attr name="position" intvalue="900"/>
                </file>
            </folder>
        </folder>
    </folder>

</filesystem>
